{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pricing-demo.local/schemas/inventory-portfolio-valuation.schema.json",
  "title": "Inventory Portfolio Valuation",
  "description": "product-spec.md §14.3. Point-in-time figures. Only total_expected_transaction_value comes from the simulation, because transaction price is a distribution rather than a stored fact.",
  "type": "object",

  "properties": {
    "active_inventory_count": { "type": "integer", "minimum": 0 },

    "total_cost_basis": { "$ref": "common-types.schema.json#/$defs/money" },
    "total_current_list_value": { "$ref": "common-types.schema.json#/$defs/money" },
    "total_internal_base_value": {
      "type": ["number", "null"],
      "description": "Sum of internal comparable estimates where computable. null-contributing vehicles are excluded and reported in data_coverage."
    },
    "total_external_market_value": { "$ref": "common-types.schema.json#/$defs/money" },

    "total_expected_transaction_value": {
      "$ref": "common-types.schema.json#/$defs/percentileSet",
      "description": "Summed within each draw, then summarized (D2). Not a sum of per-vehicle P50s."
    },

    "total_liquidation_value": {
      "type": ["number", "null"],
      "description": "null in MVP: §14.3 marks it 'if available' and no tool returns it (docs/open-questions.md C1)."
    },

    "total_pricing_variance": {
      "$ref": "common-types.schema.json#/$defs/money",
      "description": "total_current_list_value - total_external_market_value."
    },
    "total_promotional_headroom": { "$ref": "common-types.schema.json#/$defs/money" },
    "cash_tied_up": {
      "$ref": "common-types.schema.json#/$defs/money",
      "description": "total_cost_basis - floorplan financing outstanding."
    },

    "segmentation": {
      "type": "array",
      "description": "§14.4 groupings.",
      "items": {
        "type": "object",
        "properties": {
          "dimension": { "enum": ["MAKE", "MODEL", "SEGMENT", "DEAL_RATING", "CONFIDENCE", "PRICE_TO_MARKET", "AGE_BUCKET"] },
          "key": { "type": "string" },
          "unit_count": { "type": "integer" },
          "cost_basis": { "$ref": "common-types.schema.json#/$defs/money" },
          "market_value": { "$ref": "common-types.schema.json#/$defs/money" }
        },
        "required": ["dimension", "key", "unit_count"]
      }
    }
  },

  "required": [
    "active_inventory_count", "total_cost_basis", "total_current_list_value",
    "total_external_market_value", "total_expected_transaction_value",
    "total_pricing_variance", "total_promotional_headroom", "cash_tied_up"
  ]
}
